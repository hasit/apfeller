#!/bin/sh

set -eu

APFELLER_MANAGER_VERSION_TEMPLATE='__APFELLER_MANAGER_VERSION__'

default_manager_version() {
  script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

  if [ "$APFELLER_MANAGER_VERSION_TEMPLATE" != '__APFELLER_MANAGER''_VERSION__' ]; then
    printf '%s' "$APFELLER_MANAGER_VERSION_TEMPLATE"
    return 0
  fi

  if root_dir=$(CDPATH= cd -- "$script_dir/../.." 2>/dev/null && pwd); then
    if [ -f "$root_dir/VERSION" ]; then
      version=$(tr -d '\n' <"$root_dir/VERSION")
      if [ -n "$version" ]; then
        printf '%s' "$version"
        return 0
      fi
    fi
  fi

  printf '%s' '0.0.0-dev'
}

APFELLER_MANAGER_VERSION=${APFELLER_MANAGER_VERSION:-$(default_manager_version)}
MANAGER_REPO=${APFELLER_REPO:-hasit/apfeller}
APPS_REPO=${APFELLER_APPS_REPO:-hasit/apfeller-apps}
HOME_DIR=${HOME:?HOME is required}
LOCAL_BIN_DIR=${APFELLER_LOCAL_BIN_DIR:-"$HOME_DIR/.local/bin"}
CONFIG_DIR=${APFELLER_CONFIG_DIR:-"$HOME_DIR/.config/apfeller"}
DATA_DIR=${APFELLER_DATA_DIR:-"$HOME_DIR/.local/share/apfeller"}
STORE_DIR=${APFELLER_STORE_DIR:-"$DATA_DIR/store"}
STATE_PATH=${APFELLER_STATE_PATH:-"$DATA_DIR/state.tsv"}
FISH_CONF_PATH=${APFELLER_FISH_CONF_PATH:-"$HOME_DIR/.config/fish/conf.d/apfeller.fish"}
FISH_COMPLETION_DIR=${APFELLER_FISH_COMPLETION_DIR:-"$HOME_DIR/.config/fish/completions"}
ZSH_COMPLETION_DIR=${APFELLER_ZSH_COMPLETION_DIR:-"$CONFIG_DIR/completions/zsh"}
ZSH_INIT_PATH=${APFELLER_ZSH_INIT_PATH:-"$CONFIG_DIR/init.zsh"}
ZSHRC_PATH=${APFELLER_ZSHRC_PATH:-"$HOME_DIR/.zshrc"}
DETECTED_SHELL=${APFELLER_SHELL:-${SHELL:-}}
DETECTED_SHELL=${DETECTED_SHELL##*/}
DEFAULT_CATALOG_URL="https://raw.githubusercontent.com/$APPS_REPO/main/catalog/latest.tsv"
CATALOG_URL=${APFELLER_CATALOG_URL:-"$DEFAULT_CATALOG_URL"}
MANAGER_ASSET_NAME=${APFELLER_MANAGER_ASSET_NAME:-apfeller.tar.gz}
SELF_UPDATE_URL=${APFELLER_INSTALL_URL:-"https://github.com/$MANAGER_REPO/releases/latest/download/$MANAGER_ASSET_NAME"}
TAB=$(printf '\t')
US=$(printf '\034')
TMP_DIR=""
CATALOG_CACHE_PATH=""
PROGRESS_PID=""
PROGRESS_MESSAGE=""
PROGRESS_MODE=""
PROGRESS_CHARSET=""
PROGRESS_DELAY_SECONDS=0.18
PROGRESS_INTERVAL_SECONDS=0.10

print_help() {
  cat <<'EOF'
apfeller - install and manage shell apps

Usage:
  apfeller list [--installed]
  apfeller info <app>
  apfeller install <app>...
  apfeller uninstall <app>...
  apfeller update --self | --all | <app>...
  apfeller doctor
  apfeller --version
EOF
}

fail() {
  progress_abort
  printf '%s\n' "$*" >&2
  exit 1
}

ensure_dir() {
  mkdir -p "$1"
}

progress_can_render() {
  [ -t 2 ] || return 1
  [ "${TERM:-}" != "dumb" ] || return 1
}

progress_detect_charset() {
  locale=${LC_ALL:-${LC_CTYPE:-${LANG:-}}}
  locale=$(printf '%s' "$locale" | tr '[:lower:]' '[:upper:]')

  case "$locale" in
    *UTF-8*|*UTF8*)
      printf '%s\n' "unicode"
      ;;
    *)
      printf '%s\n' "ascii"
      ;;
  esac
}

progress_spin_frame() {
  charset=$1
  step=$2

  if [ "$charset" = "unicode" ]; then
    case $((step % 10)) in
      0) printf '%s' '⠋' ;;
      1) printf '%s' '⠙' ;;
      2) printf '%s' '⠹' ;;
      3) printf '%s' '⠸' ;;
      4) printf '%s' '⠼' ;;
      5) printf '%s' '⠴' ;;
      6) printf '%s' '⠦' ;;
      7) printf '%s' '⠧' ;;
      8) printf '%s' '⠇' ;;
      *) printf '%s' '⠏' ;;
    esac
    return 0
  fi

  case $((step % 5)) in
    0) printf '%s' '.  ' ;;
    1) printf '%s' '.. ' ;;
    2) printf '%s' '...' ;;
    3) printf '%s' '.. ' ;;
    *) printf '%s' '.  ' ;;
  esac
}

progress_bar_frame() {
  charset=$1
  step=$2

  if [ "$charset" = "unicode" ]; then
    case $((step % 10)) in
      0) segment='███     ' ;;
      1) segment=' ███    ' ;;
      2) segment='  ███   ' ;;
      3) segment='   ███  ' ;;
      4) segment='    ███ ' ;;
      5) segment='     ███' ;;
      6) segment='    ███ ' ;;
      7) segment='   ███  ' ;;
      8) segment='  ███   ' ;;
      *) segment=' ███    ' ;;
    esac
  else
    case $((step % 10)) in
      0) segment='###     ' ;;
      1) segment=' ###    ' ;;
      2) segment='  ###   ' ;;
      3) segment='   ###  ' ;;
      4) segment='    ### ' ;;
      5) segment='     ###' ;;
      6) segment='    ### ' ;;
      7) segment='   ###  ' ;;
      8) segment='  ###   ' ;;
      *) segment=' ###    ' ;;
    esac
  fi

  printf '[%s]' "$segment"
}

progress_frame() {
  mode=$1
  charset=$2
  step=$3

  case "$mode" in
    bar)
      progress_bar_frame "$charset" "$step"
      ;;
    *)
      progress_spin_frame "$charset" "$step"
      ;;
  esac
}

progress_start() {
  mode=$1
  message=$2

  progress_abort
  PROGRESS_MODE=$mode
  PROGRESS_MESSAGE=$message
  PROGRESS_CHARSET=$(progress_detect_charset)

  progress_can_render || return 0

  (
    trap 'exit 0' INT TERM
    sleep "$PROGRESS_DELAY_SECONDS"
    step=0
    while :; do
      frame=$(progress_frame "$PROGRESS_MODE" "$PROGRESS_CHARSET" "$step")
      printf '\r\033[2K%s %s' "$PROGRESS_MESSAGE" "$frame" >&2
      step=$((step + 1))
      sleep "$PROGRESS_INTERVAL_SECONDS"
    done
  ) &
  PROGRESS_PID=$!
}

progress_abort() {
  if [ -n "${PROGRESS_PID:-}" ]; then
    kill "$PROGRESS_PID" 2>/dev/null || true
    wait "$PROGRESS_PID" 2>/dev/null || true
    PROGRESS_PID=""
  fi

  if progress_can_render; then
    printf '\r\033[2K' >&2
  fi

  PROGRESS_MESSAGE=""
  PROGRESS_MODE=""
  PROGRESS_CHARSET=""
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

require_tools() {
  for tool in "$@"; do
    command_exists "$tool" || fail "apfeller needs $tool to do that. Install $tool and try again."
  done
}

require_tools_or_return() {
  for tool in "$@"; do
    if ! command_exists "$tool"; then
      printf '%s\n' "apfeller needs $tool to do that. Install $tool and try again." >&2
      return 127
    fi
  done
}

print_download_failure_help() {
  label=$1
  status=$2

  case "$label" in
    'app catalog')
      printf '%s\n' "apfeller could not load the app catalog right now." >&2
      ;;
    'manager archive')
      printf '%s\n' "apfeller could not download its latest files right now." >&2
      ;;
    *' app bundle')
      app_id=${label% app bundle}
      printf '%s\n' "apfeller could not download $app_id right now." >&2
      ;;
    *)
      printf '%s\n' "apfeller could not finish this download right now." >&2
      ;;
  esac

  case "$status" in
    6|7|28|35|56)
      printf '%s\n' "Check your internet connection and try again." >&2
      ;;
    22)
      printf '%s\n' "That download is not available right now. Please try again later." >&2
      ;;
    *)
      printf '%s\n' "Please try again in a moment." >&2
      ;;
  esac
}

download_to_path() {
  url=$1
  output_path=$2
  label=$3
  progress_message=$4
  curl_error_path=$(mktemp "${TMPDIR:-/tmp}/apfeller-curl.XXXXXX")

  progress_start bar "$progress_message"

  set +e
  curl -fsSL "$url" -o "$output_path" 2>"$curl_error_path"
  status=$?
  set -e

  progress_abort

  if [ "$status" -eq 0 ]; then
    rm -f "$curl_error_path"
    return 0
  fi

  rm -f "$curl_error_path"

  progress_abort
  print_download_failure_help "$label" "$status"
  return "$status"
}

shell_quote() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

escape_double_quotes() {
  printf '%s' "$1" | sed 's/[\\"]/\\&/g'
}

status_for_path() {
  if [ -e "$1" ] || [ -L "$1" ]; then
    printf '%s\n' "present"
  else
    printf '%s\n' "missing"
  fi
}

detect_shell_kind() {
  case "$1" in
    fish)
      printf '%s\n' "fish"
      ;;
    zsh)
      printf '%s\n' "zsh"
      ;;
    *)
      printf '%s\n' "unknown"
      ;;
  esac
}

split_csv() {
  csv=$1
  [ -n "$csv" ] || return 0

  old_ifs=$IFS
  IFS=,
  # shellcheck disable=SC2086
  set -- $csv
  IFS=$old_ifs

  for item in "$@"; do
    [ -n "$item" ] || continue
    printf '%s\n' "$item"
  done
}

trim() {
  printf '%s' "$1" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

contains_csv() {
  csv=$1
  item=$2

  case ",$csv," in
    *,"$item",*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

sanitize_name() {
  printf '%s' "$1" | tr '[:lower:]-' '[:upper:]_' | tr -cd 'A-Z0-9_'
}

ensure_state_file() {
  ensure_dir "$(dirname "$STATE_PATH")"
  if [ ! -f "$STATE_PATH" ]; then
    printf 'id\trevision\tcommand\tinstalled_at\n' >"$STATE_PATH"
  fi
}

clear_catalog_entry() {
  CAT_ID=
  CAT_REVISION=
  CAT_SUMMARY=
  CAT_DESCRIPTION=
  CAT_COMMAND=
  CAT_KIND=
  CAT_REQUIRES=
  CAT_SUPPORTED_SHELLS=
  CAT_BUNDLE_URL=
  CAT_SHA256=
}

state_has_apps() {
  [ -f "$STATE_PATH" ] || return 1
  awk 'NR > 1 { found = 1; exit } END { exit found ? 0 : 1 }' "$STATE_PATH"
}

state_has_app() {
  app_id=$1
  [ -f "$STATE_PATH" ] || return 1
  awk -F '\t' -v app="$app_id" '
    NR > 1 && $1 == app {
      found = 1
      exit
    }
    END {
      exit found ? 0 : 1
    }
  ' "$STATE_PATH"
}

state_get_field() {
  app_id=$1
  field_index=$2
  [ -f "$STATE_PATH" ] || return 0
  awk -F '\t' -v app="$app_id" -v field="$field_index" '
    NR > 1 && $1 == app {
      print $field
      exit
    }
  ' "$STATE_PATH"
}

state_remove() {
  app_id=$1
  ensure_state_file
  tmp_state=$(mktemp "$TMP_DIR/state.XXXXXX")
  awk -F '\t' -v app="$app_id" '
    NR == 1 || $1 != app {
      print $0
    }
  ' "$STATE_PATH" >"$tmp_state"
  mv "$tmp_state" "$STATE_PATH"
}

state_upsert() {
  app_id=$1
  revision=$2
  command_name=$3
  installed_at=$4

  ensure_state_file
  state_remove "$app_id"
  printf '%s\t%s\t%s\t%s\n' "$app_id" "$revision" "$command_name" "$installed_at" >>"$STATE_PATH"
}

fetch_catalog() {
  require_tools curl
  if [ -z "$CATALOG_CACHE_PATH" ]; then
    CATALOG_CACHE_PATH="$TMP_DIR/apfeller-catalog.tsv"
    download_to_path "$CATALOG_URL" "$CATALOG_CACHE_PATH" "app catalog" "Downloading app catalog..."
  fi
  printf '%s\n' "$CATALOG_CACHE_PATH"
}

load_catalog_entry() {
  app_id=$1
  catalog_file=$2

  clear_catalog_entry

  entry_data=$(
    awk -F '\t' -v app="$app_id" -v sep="$US" '
      NR > 1 && $1 == app {
        printf "%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s", $1, sep, $2, sep, $3, sep, $4, sep, $5, sep, $6, sep, $7, sep, $8, sep, $9, sep, $10
        found = 1
        exit
      }
      END {
        if (!found) {
          exit 1
        }
      }
    ' "$catalog_file"
  ) || return 1

  old_ifs=$IFS
  IFS=$US
  # shellcheck disable=SC2086
  set -- $entry_data
  IFS=$old_ifs

  CAT_ID=$1
  shift
  CAT_REVISION=$1
  shift
  CAT_SUMMARY=$1
  shift
  CAT_DESCRIPTION=$1
  shift
  CAT_COMMAND=$1
  shift
  CAT_KIND=$1
  shift
  CAT_REQUIRES=$1
  shift
  CAT_SUPPORTED_SHELLS=$1
  shift
  CAT_BUNDLE_URL=$1
  shift
  CAT_SHA256=$1
}

resolve_app_state() {
  app_id=$1
  catalog_file=$2

  APP_INSTALLED_REVISION=$(state_get_field "$app_id" 2)
  APP_INSTALLED_COMMAND=$(state_get_field "$app_id" 3)
  APP_CATALOG_REVISION=

  if load_catalog_entry "$app_id" "$catalog_file"; then
    APP_CATALOG_REVISION=$CAT_REVISION
    if [ -z "$APP_INSTALLED_REVISION" ]; then
      APP_STATE=available
    elif [ "$APP_INSTALLED_REVISION" = "$CAT_REVISION" ]; then
      APP_STATE=installed
    else
      APP_STATE=update-available
    fi
    return 0
  fi

  if [ -n "$APP_INSTALLED_REVISION" ]; then
    APP_STATE=local-only
  else
    APP_STATE=missing
  fi
}

print_local_only_warning() {
  app_id=$1
  printf '%s\n' "$app_id is installed locally, but it is no longer in the current catalog." >&2
}

print_manager_update_continue_warning() {
  printf '%s\n' "apfeller could not update itself right now. Continuing with the installed version." >&2
}

print_manager_update_check_warning() {
  printf '%s\n' "apfeller could not check for updates right now. Continuing with the installed version." >&2
}

probe_latest_manager_version() {
  require_tools_or_return curl || return 1

  curl_error_path=$(mktemp "${TMPDIR:-/tmp}/apfeller-curl.XXXXXX")
  progress_start spin "Checking for apfeller updates..."

  set +e
  effective_url=$(curl -fsSIL -o /dev/null -w '%{url_effective}' "$SELF_UPDATE_URL" 2>"$curl_error_path")
  status=$?
  if [ "$status" -ne 0 ] && [ "${APFELLER_INSTALL_URL+x}" = "x" ]; then
    effective_url=$(curl -fsSL -o /dev/null -w '%{url_effective}' "$SELF_UPDATE_URL" 2>"$curl_error_path")
    status=$?
  fi
  set -e

  rm -f "$curl_error_path"
  progress_abort

  [ "$status" -eq 0 ] || return 1

  version=$(printf '%s\n' "$effective_url" | sed -n 's#.*/download/v\([^/]*\)/[^/]*$#\1#p')
  [ -n "$version" ] || return 2

  printf '%s\n' "$version"
}

reexec_install_command() {
  [ -x "$LOCAL_BIN_DIR/apfeller" ] || fail "apfeller updated itself, but could not continue. Run the install again."
  APFELLER_SKIP_AUTO_SELF_UPDATE=1 exec "$LOCAL_BIN_DIR/apfeller" install "$@"
}

install_manager_completions() {
  extracted_root=$1

  if [ -f "$extracted_root/completions/fish/apfeller.fish" ]; then
    ensure_dir "$FISH_COMPLETION_DIR"
    cp "$extracted_root/completions/fish/apfeller.fish" "$FISH_COMPLETION_DIR/apfeller.fish"
  fi

  if [ -f "$extracted_root/completions/zsh/_apfeller" ]; then
    ensure_dir "$ZSH_COMPLETION_DIR"
    cp "$extracted_root/completions/zsh/_apfeller" "$ZSH_COMPLETION_DIR/_apfeller"
  fi
}

write_fish_conf() {
  ensure_dir "$(dirname "$FISH_CONF_PATH")"
  cat >"$FISH_CONF_PATH" <<EOF
set -gx APFELLER_HOME "\$HOME/.config/apfeller"
if not contains -- "$LOCAL_BIN_DIR" \$PATH
    set -gx PATH "$LOCAL_BIN_DIR" \$PATH
end
EOF
}

write_zsh_init() {
  ensure_dir "$(dirname "$ZSH_INIT_PATH")"
  cat >"$ZSH_INIT_PATH" <<EOF
export APFELLER_HOME="\$HOME/.config/apfeller"
if [[ ":\$PATH:" != *":$LOCAL_BIN_DIR:"* ]]; then
  export PATH="$LOCAL_BIN_DIR:\$PATH"
fi
APFELLER_ZSH_COMPLETIONS="$ZSH_COMPLETION_DIR"
if [[ -d "\$APFELLER_ZSH_COMPLETIONS" ]]; then
  fpath=("\$APFELLER_ZSH_COMPLETIONS" \$fpath)
fi
autoload -Uz compinit
if ! whence compdef >/dev/null 2>&1; then
  compinit -i
fi
EOF
}

ensure_zsh_source_block() {
  block=$(cat <<EOF
# >>> apfeller >>>
[ -f "$ZSH_INIT_PATH" ] && source "$ZSH_INIT_PATH"
# <<< apfeller <<<
EOF
)
  block_file=$(mktemp "$TMP_DIR/block.XXXXXX")
  printf '%s\n' "$block" >"$block_file"

  if [ ! -f "$ZSHRC_PATH" ]; then
    printf '%s\n' "$block" >"$ZSHRC_PATH"
    rm -f "$block_file"
    return
  fi

  tmp_output=$(mktemp "$TMP_DIR/zshrc.XXXXXX")
  awk -v start='# >>> apfeller >>>' -v end='# <<< apfeller <<<' -v block_file="$block_file" '
    function emit_block(    line) {
      while ((getline line < block_file) > 0) {
        print line
      }
      close(block_file)
    }
    $0 == start {
      emit_block()
      skipping = 1
      replaced = 1
      next
    }
    $0 == end {
      skipping = 0
      next
    }
    skipping {
      next
    }
    {
      print
    }
    END {
      if (!replaced) {
        if (NR > 0) {
          print ""
        }
        emit_block()
      }
    }
  ' "$ZSHRC_PATH" >"$tmp_output"

  mv "$tmp_output" "$ZSHRC_PATH"
  rm -f "$block_file"
}

apply_shell_setup() {
  case "$DETECTED_SHELL" in
    fish)
      write_fish_conf
      return 0
      ;;
    zsh)
      write_zsh_init
      ensure_zsh_source_block
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

install_manager_from_archive() {
  archive_url=$1
  require_tools_or_return curl tar || return $?

  archive_path="$TMP_DIR/$MANAGER_ASSET_NAME"
  extract_dir="$TMP_DIR/manager"

  rm -rf "$extract_dir"
  mkdir -p "$extract_dir"

  if ! download_to_path "$archive_url" "$archive_path" "manager archive" "Downloading apfeller update..."; then
    return 1
  fi
  progress_start spin "Updating apfeller..."
  if ! tar -xzf "$archive_path" -C "$extract_dir" >/dev/null 2>&1; then
    progress_abort
    printf '%s\n' "The downloaded apfeller update looks incomplete. Please try again later." >&2
    return 1
  fi

  if [ ! -f "$extract_dir/bin/apfeller" ]; then
    progress_abort
    printf '%s\n' "The downloaded apfeller update looks incomplete. Please try again later." >&2
    return 1
  fi

  ensure_dir "$LOCAL_BIN_DIR"
  ensure_dir "$CONFIG_DIR"
  if ! cp "$extract_dir/bin/apfeller" "$LOCAL_BIN_DIR/apfeller"; then
    progress_abort
    printf '%s\n' "apfeller could not update itself right now. Please try again later." >&2
    return 1
  fi
  if ! chmod +x "$LOCAL_BIN_DIR/apfeller"; then
    progress_abort
    printf '%s\n' "apfeller could not update itself right now. Please try again later." >&2
    return 1
  fi
  if ! install_manager_completions "$extract_dir"; then
    progress_abort
    printf '%s\n' "apfeller could not update itself right now. Please try again later." >&2
    return 1
  fi

  progress_abort
  if apply_shell_setup; then
    printf '%s\n' "Updated apfeller"
  else
    printf '%s\n' "Updated apfeller at $LOCAL_BIN_DIR/apfeller"
    printf '%s\n' "Run this once for the current shell: export PATH=\"$LOCAL_BIN_DIR:\$PATH\""
  fi

  return 0
}

check_required_commands() {
  app_id=$1
  requires=$2

  [ -n "$requires" ] || return 0

  split_csv "$requires" | while IFS= read -r required; do
    command_exists "$required" || fail "$app_id needs $required before it can run. Install $required and try again."
  done
}

is_managed_symlink() {
  path=$1

  [ -L "$path" ] || return 1
  target=$(readlink "$path" 2>/dev/null || true)

  case "$target" in
    "$STORE_DIR"/*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

ensure_command_slot_available() {
  command_name=$1
  command_path="$LOCAL_BIN_DIR/$command_name"

  if [ -e "$command_path" ] || [ -L "$command_path" ]; then
    if ! is_managed_symlink "$command_path"; then
      fail "apfeller will not replace the existing '$command_name' command at $command_path."
    fi
  fi

  existing_command=$(command -v "$command_name" 2>/dev/null || true)
  if [ -n "$existing_command" ] && [ "$existing_command" != "$command_path" ]; then
    fail "apfeller will not replace the existing '$command_name' command at $existing_command."
  fi
}

load_runtime_manifest() {
  app_dir=$1
  APP_RUNTIME_MANIFEST="$app_dir/runtime/manifest.env"
  APP_ARGS_PATH="$app_dir/runtime/args.tsv"
  APP_EXAMPLES_PATH="$app_dir/runtime/examples.txt"

  [ -f "$APP_RUNTIME_MANIFEST" ] || fail "This app's files look incomplete. Please reinstall it."
  [ -f "$APP_ARGS_PATH" ] || fail "This app's files look incomplete. Please reinstall it."
  [ -f "$APP_EXAMPLES_PATH" ] || fail "This app's files look incomplete. Please reinstall it."

  APFELLER_APP_ID=
  APFELLER_APP_REVISION=
  APFELLER_APP_SUMMARY=
  APFELLER_APP_DESCRIPTION=
  APFELLER_APP_COMMAND=
  APFELLER_APP_KIND=
  APFELLER_APP_REQUIRES=
  APFELLER_APP_SUPPORTED_SHELLS=
  APFELLER_HELP_USAGE=
  APFELLER_INPUT_MODE=
  APFELLER_INPUT_NAME=
  APFELLER_INPUT_REQUIRED=
  APFELLER_PROMPT_SYSTEM=
  APFELLER_PROMPT_TEMPLATE=
  APFELLER_PROMPT_MAX_CONTEXT_TOKENS=
  APFELLER_PROMPT_MAX_INPUT_BYTES=
  APFELLER_PROMPT_MAX_OUTPUT_TOKENS=
  APFELLER_OUTPUT_MODE=
  APFELLER_OUTPUT_FIELDS=
  APFELLER_HOOK_BUILD_PROMPT=
  APFELLER_HOOK_PRE_RUN=

  # shellcheck disable=SC1090
  . "$APP_RUNTIME_MANIFEST"
}

generate_app_wrapper() {
  store_path=$1
  command_name=$2

  wrapper_dir="$store_path/bin"
  wrapper_path="$wrapper_dir/$command_name"
  ensure_dir "$wrapper_dir"

  cat >"$wrapper_path" <<'EOF'
#!/bin/sh

set -eu

script_path=$0
while [ -L "$script_path" ]; do
  target=$(readlink "$script_path")
  case "$target" in
    /*)
      script_path=$target
      ;;
    *)
      script_path=$(dirname "$script_path")/$target
      ;;
  esac
done

APP_DIR=$(CDPATH= cd -- "$(dirname -- "$script_path")/.." && pwd)
APFELLER_MANAGER_BIN=${APFELLER_MANAGER_BIN:-apfeller}

exec "$APFELLER_MANAGER_BIN" __run-app "$APP_DIR" "$@"
EOF

  chmod +x "$wrapper_path"
}

write_fish_completion() {
  store_path=$1
  command_name=$2

  load_runtime_manifest "$store_path"
  completion_path="$store_path/completions/fish/$command_name.fish"
  ensure_dir "$(dirname "$completion_path")"

  {
    printf 'complete -c %s -f -s h -l help -d "%s"\n' "$command_name" "Show this help"

    case "$APFELLER_OUTPUT_MODE" in
      shell_command)
        printf 'complete -c %s -f -s c -l copy -d "%s"\n' "$command_name" "Copy the generated command to the clipboard"
        printf 'complete -c %s -f -s x -l execute -d "%s"\n' "$command_name" "Run the generated command after confirmation"
        ;;
      text|structured_text)
        printf 'complete -c %s -f -s c -l copy -d "%s"\n' "$command_name" "Copy the response to the clipboard"
        ;;
    esac

    while IFS="$TAB" read -r arg_name arg_type arg_long arg_short arg_description arg_default arg_choices; do
      [ "$arg_name" = "name" ] && continue
      [ -n "$arg_name" ] || continue

      command_line=$(printf 'complete -c %s -f' "$command_name")
      if [ -n "$arg_short" ]; then
        command_line="$command_line -s $arg_short"
      fi
      command_line="$command_line -l $arg_long"

      case "$arg_type" in
        string|integer|enum)
          command_line="$command_line -r"
          ;;
      esac

      if [ "$arg_type" = "enum" ] && [ -n "$arg_choices" ]; then
        fish_choices=$(printf '%s' "$arg_choices" | tr ',' ' ')
        command_line="$command_line -a \"$(escape_double_quotes "$fish_choices")\""
      fi

      command_line="$command_line -d \"$(escape_double_quotes "$arg_description")\""
      printf '%s\n' "$command_line"
    done <"$APP_ARGS_PATH"
  } >"$completion_path"
}

write_zsh_completion() {
  store_path=$1
  command_name=$2

  load_runtime_manifest "$store_path"
  completion_path="$store_path/completions/zsh/_$command_name"
  ensure_dir "$(dirname "$completion_path")"

  {
    printf '#compdef %s\n\n' "$command_name"
    printf '_arguments \\\n'
    printf "  '-h[Show this help]' \\\n"
    printf "  '--help[Show this help]' \\\n"

    case "$APFELLER_OUTPUT_MODE" in
      shell_command)
        printf "  '-c[Copy the generated command to the clipboard]' \\\n"
        printf "  '--copy[Copy the generated command to the clipboard]' \\\n"
        printf "  '-x[Run the generated command after confirmation]' \\\n"
        printf "  '--execute[Run the generated command after confirmation]' \\\n"
        ;;
      text|structured_text)
        printf "  '-c[Copy the response to the clipboard]' \\\n"
        printf "  '--copy[Copy the response to the clipboard]' \\\n"
        ;;
    esac

    while IFS="$TAB" read -r arg_name arg_type arg_long arg_short arg_description arg_default arg_choices; do
      [ "$arg_name" = "name" ] && continue
      [ -n "$arg_name" ] || continue

      description=$(escape_double_quotes "$arg_description")
      suffix=''
      case "$arg_type" in
        string)
          suffix=":value:"
          ;;
        integer)
          suffix=":integer:"
          ;;
        enum)
          if [ -n "$arg_choices" ]; then
            choices=$(printf '%s' "$arg_choices" | tr ',' ' ')
            suffix=":value:($(escape_double_quotes "$choices"))"
          else
            suffix=":value:"
          fi
          ;;
      esac

      if [ -n "$arg_short" ]; then
        printf "  '-%s[%s]%s' \\\n" "$arg_short" "$description" "$suffix"
      fi
      printf "  '--%s[%s]%s' \\\n" "$arg_long" "$description" "$suffix"
    done <"$APP_ARGS_PATH"

    printf "  '*:input:_files'\n"
  } >"$completion_path"
}

install_app_completions() {
  store_path=$1
  command_name=$2

  write_fish_completion "$store_path" "$command_name"
  write_zsh_completion "$store_path" "$command_name"

  if [ -f "$store_path/completions/fish/$command_name.fish" ]; then
    ensure_dir "$FISH_COMPLETION_DIR"
    cp "$store_path/completions/fish/$command_name.fish" "$FISH_COMPLETION_DIR/$command_name.fish"
  fi

  if [ -f "$store_path/completions/zsh/_$command_name" ]; then
    ensure_dir "$ZSH_COMPLETION_DIR"
    cp "$store_path/completions/zsh/_$command_name" "$ZSH_COMPLETION_DIR/_$command_name"
  fi
}

install_app() {
  app_id=$1
  catalog_file=$2

  load_catalog_entry "$app_id" "$catalog_file" || fail "App not found in the current catalog: $app_id. Run 'apfeller list' to see what's available."

  [ -n "$CAT_SHA256" ] || fail "apfeller could not verify $app_id right now. Please try again later."
  require_tools curl tar shasum
  check_required_commands "$CAT_ID" "$CAT_REQUIRES"

  command_name=$CAT_COMMAND
  command_path="$LOCAL_BIN_DIR/$command_name"
  bundle_url=$CAT_BUNDLE_URL
  bundle_name=${bundle_url##*/}
  archive_path="$TMP_DIR/$CAT_ID-$CAT_REVISION.tar.gz"
  extract_dir="$TMP_DIR/extract-$CAT_ID"
  store_path="$STORE_DIR/$CAT_ID/$CAT_REVISION"
  previous_revision=$(state_get_field "$CAT_ID" 2)

  ensure_dir "$LOCAL_BIN_DIR"
  ensure_dir "$DATA_DIR"
  ensure_dir "$STORE_DIR"
  ensure_dir "$(dirname "$store_path")"
  ensure_command_slot_available "$command_name"

  download_to_path "$bundle_url" "$archive_path" "$CAT_ID app bundle" "Downloading $CAT_ID..."
  progress_start spin "Installing $CAT_ID..."
  actual_sha=$(shasum -a 256 "$archive_path" | awk '{print $1}')
  if [ "$actual_sha" != "$CAT_SHA256" ]; then
    fail "The downloaded files for $CAT_ID could not be verified. Please try again later."
  fi

  rm -rf "$extract_dir"
  mkdir -p "$extract_dir"
  tar -xzf "$archive_path" -C "$extract_dir"

  load_runtime_manifest "$extract_dir"
  [ "$APFELLER_APP_COMMAND" = "$CAT_COMMAND" ] || fail "The downloaded files for $CAT_ID look incomplete or invalid. Please try again later."
  [ "$APFELLER_APP_KIND" = "$CAT_KIND" ] || fail "The downloaded files for $CAT_ID look incomplete or invalid. Please try again later."
  [ "$APFELLER_APP_REVISION" = "$CAT_REVISION" ] || fail "The downloaded files for $CAT_ID look incomplete or invalid. Please try again later."

  rm -rf "$store_path"
  mv "$extract_dir" "$store_path"

  generate_app_wrapper "$store_path" "$command_name"

  rm -f "$command_path"
  ln -s "$store_path/bin/$command_name" "$command_path"
  install_app_completions "$store_path" "$command_name"

  installed_at=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
  state_upsert "$CAT_ID" "$CAT_REVISION" "$CAT_COMMAND" "$installed_at"

  if [ -n "$previous_revision" ] && [ "$previous_revision" != "$CAT_REVISION" ]; then
    rm -rf "$STORE_DIR/$CAT_ID/$previous_revision"
  fi

  progress_abort
  if [ -n "$previous_revision" ] && [ "$previous_revision" != "$CAT_REVISION" ]; then
    printf 'Updated %s %s -> %s\n' "$CAT_ID" "$previous_revision" "$CAT_REVISION"
  else
    printf 'Installed %s %s\n' "$CAT_ID" "$CAT_REVISION"
  fi
}

ensure_manager_current_for_install() {
  latest_version=
  probe_status=0

  [ "${APFELLER_SKIP_AUTO_SELF_UPDATE:-0}" = "1" ] && return 0

  set +e
  latest_version=$(probe_latest_manager_version)
  probe_status=$?
  set -e

  if [ "$probe_status" -eq 0 ]; then
    if [ "$latest_version" = "$APFELLER_MANAGER_VERSION" ]; then
      return 0
    fi

    if install_manager_from_archive "$SELF_UPDATE_URL"; then
      reexec_install_command "$@"
    fi

    print_manager_update_continue_warning
    return 0
  fi

  if [ "$probe_status" -eq 2 ] && [ "${APFELLER_INSTALL_URL+x}" = "x" ]; then
    if install_manager_from_archive "$SELF_UPDATE_URL"; then
      reexec_install_command "$@"
    fi

    print_manager_update_continue_warning
    return 0
  fi

  print_manager_update_check_warning
  return 0
}

uninstall_app() {
  app_id=$1

  revision=$(state_get_field "$app_id" 2)
  command_name=$(state_get_field "$app_id" 3)

  if [ -z "$revision" ] || [ -z "$command_name" ]; then
    printf '%s is not installed.\n' "$app_id"
    return 0
  fi

  command_path="$LOCAL_BIN_DIR/$command_name"
  fish_completion_path="$FISH_COMPLETION_DIR/$command_name.fish"
  zsh_completion_path="$ZSH_COMPLETION_DIR/_$command_name"
  store_path="$STORE_DIR/$app_id/$revision"

  if is_managed_symlink "$command_path"; then
    rm -f "$command_path"
  fi

  rm -f "$fish_completion_path"
  rm -f "$zsh_completion_path"
  rm -rf "$store_path"
  state_remove "$app_id"

  printf 'Removed %s\n' "$app_id"
}

apfeller_require_apfel() {
  if command -v "${APFELLER_APFEL_BIN:-apfel}" >/dev/null 2>&1; then
    return 0
  fi

  printf '%s\n' "This app needs apfel before it can run. Install it with: brew install Arthur-Ficial/tap/apfel" >&2
  return 127
}

apfeller_count_bytes() {
  LC_ALL=C printf '%s' "$1" | wc -c | awk '{print $1}'
}

apfeller_require_context_budget() {
  app_name=$1
  max_context_tokens=$2
  max_input_bytes=$3
  max_output_tokens=$4
  user_prompt=$5

  prompt_bytes=$(apfeller_count_bytes "$user_prompt")
  effective_limit=$((max_context_tokens - max_output_tokens - 256))
  if [ "$max_input_bytes" -lt "$effective_limit" ]; then
    effective_limit=$max_input_bytes
  fi

  if [ "$prompt_bytes" -gt "$effective_limit" ]; then
    printf '%s\n' "Input too large for $app_name; keep it under $effective_limit bytes so it fits apfel's ${max_context_tokens}-token window." >&2
    return 1
  fi
}

apfeller_query() {
  max_tokens=$1
  system_prompt=$2
  user_prompt=$3

  apfeller_require_apfel || return $?

  "${APFELLER_APFEL_BIN:-apfel}" \
    -q \
    --no-color \
    --temperature 0 \
    --seed 1 \
    --max-tokens "$max_tokens" \
    -s "$system_prompt" \
    "$user_prompt"
}

apfeller_clean_command() {
  cleaned=$(
    printf '%s\n' "$1" | awk '
      {
        gsub(/^[[:space:]]+/, "", $0)
        gsub(/[[:space:]]+$/, "", $0)
        if ($0 == "" || $0 ~ /^```/ || $0 ~ /^#/) {
          next
        }
        sub(/^\$[[:space:]]*/, "", $0)
        print
        exit
      }
    '
  )

  [ -n "$cleaned" ] || return 1
  printf '%s\n' "$cleaned"
}

apfeller_copy() {
  if ! command -v pbcopy >/dev/null 2>&1; then
    printf '%s\n' "Copying needs pbcopy, but pbcopy is not available on this system." >&2
    return 127
  fi

  printf '%s' "$1" | pbcopy
}

runtime_query_response() {
  prompt=$1

  progress_start spin "Running $APFELLER_APP_COMMAND..."
  set +e
  response=$(apfeller_query "$APFELLER_PROMPT_MAX_OUTPUT_TOKENS" "$APFELLER_PROMPT_SYSTEM" "$prompt")
  status=$?
  set -e
  progress_abort

  [ "$status" -eq 0 ] || return "$status"
  printf '%s' "$response"
}

apfeller_confirm() {
  prompt=$1
  printf '%s' "$prompt"
  IFS= read -r response || return 1

  case "$response" in
    y|Y)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

template_replace_literal() {
  template=$1
  token=$2
  value=$3

  awk -v template="$template" -v token="$token" -v value="$value" '
    function replace_all(text, token, value,    out, pos, token_len) {
      out = ""
      token_len = length(token)
      while ((pos = index(text, token)) > 0) {
        out = out substr(text, 1, pos - 1) value
        text = substr(text, pos + token_len)
      }
      return out text
    }
    BEGIN {
      print replace_all(template, token, value)
    }
  '
}

arg_record_by_long() {
  option_name=$1
  awk -F '\t' -v option="$option_name" -v sep="$US" '
    NR > 1 && $3 == option {
      printf "%s%s%s%s%s%s%s%s%s%s%s%s%s", $1, sep, $2, sep, $3, sep, $4, sep, $5, sep, $6, sep, $7
      found = 1
      exit
    }
    END {
      exit found ? 0 : 1
    }
  ' "$APP_ARGS_PATH"
}

arg_record_by_short() {
  option_name=$1
  awk -F '\t' -v option="$option_name" -v sep="$US" '
    NR > 1 && $4 == option {
      printf "%s%s%s%s%s%s%s%s%s%s%s%s%s", $1, sep, $2, sep, $3, sep, $4, sep, $5, sep, $6, sep, $7
      found = 1
      exit
    }
    END {
      exit found ? 0 : 1
    }
  ' "$APP_ARGS_PATH"
}

parse_arg_record() {
  record=$1
  old_ifs=$IFS
  IFS=$US
  # shellcheck disable=SC2086
  set -- $record
  IFS=$old_ifs

  ARG_REC_NAME=${1-}
  shift
  ARG_REC_TYPE=${1-}
  shift
  ARG_REC_LONG=${1-}
  shift
  ARG_REC_SHORT=${1-}
  shift
  ARG_REC_DESCRIPTION=${1-}
  shift
  ARG_REC_DEFAULT=${1-}
  shift
  ARG_REC_CHOICES=${1-}
}

runtime_set_arg_value() {
  arg_name=$1
  arg_value=$2
  var_name=RUN_ARG_$(sanitize_name "$arg_name")
  eval "$var_name=$(shell_quote "$arg_value")"
}

runtime_get_arg_value() {
  arg_name=$1
  var_name=RUN_ARG_$(sanitize_name "$arg_name")
  eval "printf '%s\n' \"\${$var_name:-}\""
}

runtime_initialize_arg_defaults() {
  while IFS="$TAB" read -r arg_name arg_type arg_long arg_short arg_description arg_default arg_choices; do
    [ "$arg_name" = "name" ] && continue
    [ -n "$arg_name" ] || continue
    runtime_set_arg_value "$arg_name" "$arg_default"
  done <"$APP_ARGS_PATH"
}

runtime_validate_option_value() {
  arg_name=$1
  arg_type=$2
  arg_value=$3
  arg_choices=$4

  case "$arg_type" in
    string)
      return 0
      ;;
    integer)
      case "$arg_value" in
        ''|*[!0-9]*)
          fail "Option --$arg_name expects an integer"
          ;;
      esac
      ;;
    enum)
      contains_csv "$arg_choices" "$arg_value" || fail "Option --$arg_name must be one of: $arg_choices"
      ;;
  esac
}

runtime_supports_copy() {
  case "$APFELLER_OUTPUT_MODE" in
    shell_command|text|structured_text)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

runtime_append_positional() {
  value=$1
  RUN_POSITIONAL_COUNT=$((RUN_POSITIONAL_COUNT + 1))

  if [ -z "$RUN_POSITIONAL_FIRST" ]; then
    RUN_POSITIONAL_FIRST=$value
  fi

  if [ -z "$RUN_POSITIONAL_JOINED" ]; then
    RUN_POSITIONAL_JOINED=$value
  else
    RUN_POSITIONAL_JOINED="$RUN_POSITIONAL_JOINED $value"
  fi
}

runtime_finalize_input() {
  case "$APFELLER_INPUT_MODE" in
    none)
      [ "$RUN_POSITIONAL_COUNT" -eq 0 ] || fail "Usage: $APFELLER_HELP_USAGE"
      APPRUN_INPUT=
      ;;
    single)
      if [ "$APFELLER_INPUT_REQUIRED" = "1" ]; then
        [ "$RUN_POSITIONAL_COUNT" -eq 1 ] || fail "Usage: $APFELLER_HELP_USAGE"
      else
        [ "$RUN_POSITIONAL_COUNT" -le 1 ] || fail "Usage: $APFELLER_HELP_USAGE"
      fi
      APPRUN_INPUT=$RUN_POSITIONAL_FIRST
      ;;
    rest)
      if [ "$APFELLER_INPUT_REQUIRED" = "1" ]; then
        [ "$RUN_POSITIONAL_COUNT" -gt 0 ] || fail "Usage: $APFELLER_HELP_USAGE"
      fi
      APPRUN_INPUT=$RUN_POSITIONAL_JOINED
      ;;
    *)
      fail "Unsupported input mode: $APFELLER_INPUT_MODE"
      ;;
  esac
}

runtime_parse_args() {
  RUN_SHOW_HELP=0
  RUN_SHOULD_COPY=0
  RUN_SHOULD_EXECUTE=0
  RUN_POSITIONAL_COUNT=0
  RUN_POSITIONAL_FIRST=
  RUN_POSITIONAL_JOINED=
  APPRUN_INPUT=

  runtime_initialize_arg_defaults

  while [ $# -gt 0 ]; do
    case "$1" in
      -h|--help)
        RUN_SHOW_HELP=1
        shift
        ;;
      -c|--copy)
        runtime_supports_copy || fail "Unknown option: $1"
        RUN_SHOULD_COPY=1
        shift
        ;;
      -x|--execute)
        [ "$APFELLER_OUTPUT_MODE" = "shell_command" ] || fail "Unknown option: $1"
        RUN_SHOULD_EXECUTE=1
        shift
        ;;
      --)
        shift
        while [ $# -gt 0 ]; do
          runtime_append_positional "$1"
          shift
        done
        ;;
      --*=*)
        option_name=${1%%=*}
        option_name=${option_name#--}
        option_value=${1#*=}
        record=$(arg_record_by_long "$option_name") || fail "Unknown option: --$option_name"
        parse_arg_record "$record"
        [ "$ARG_REC_TYPE" != "flag" ] || fail "Option --$option_name does not take a value"
        runtime_validate_option_value "$ARG_REC_LONG" "$ARG_REC_TYPE" "$option_value" "$ARG_REC_CHOICES"
        runtime_set_arg_value "$ARG_REC_NAME" "$option_value"
        shift
        ;;
      --*)
        option_name=${1#--}
        record=$(arg_record_by_long "$option_name") || fail "Unknown option: --$option_name"
        parse_arg_record "$record"
        if [ "$ARG_REC_TYPE" = "flag" ]; then
          runtime_set_arg_value "$ARG_REC_NAME" "1"
          shift
        else
          [ $# -ge 2 ] || fail "Option --$option_name requires a value"
          option_value=$2
          runtime_validate_option_value "$ARG_REC_LONG" "$ARG_REC_TYPE" "$option_value" "$ARG_REC_CHOICES"
          runtime_set_arg_value "$ARG_REC_NAME" "$option_value"
          shift 2
        fi
        ;;
      -?*)
        short_option=${1#-}
        [ "${#short_option}" -eq 1 ] || fail "Unknown option: $1"
        record=$(arg_record_by_short "$short_option") || fail "Unknown option: -$short_option"
        parse_arg_record "$record"
        if [ "$ARG_REC_TYPE" = "flag" ]; then
          runtime_set_arg_value "$ARG_REC_NAME" "1"
          shift
        else
          [ $# -ge 2 ] || fail "Option -$short_option requires a value"
          option_value=$2
          runtime_validate_option_value "$ARG_REC_LONG" "$ARG_REC_TYPE" "$option_value" "$ARG_REC_CHOICES"
          runtime_set_arg_value "$ARG_REC_NAME" "$option_value"
          shift 2
        fi
        ;;
      *)
        runtime_append_positional "$1"
        shift
        ;;
    esac
  done

  if [ "$RUN_SHOW_HELP" = "1" ]; then
    APPRUN_INPUT=
    return 0
  fi

  runtime_finalize_input
}

runtime_print_help() {
  printf '%s - %s\n\n' "$APFELLER_APP_COMMAND" "$APFELLER_APP_SUMMARY"
  printf 'Usage: %s\n\n' "$APFELLER_HELP_USAGE"
  printf '%s\n\n' "$APFELLER_APP_DESCRIPTION"
  printf 'Options:\n'
  printf '  -h, --help     Show this help\n'

  case "$APFELLER_OUTPUT_MODE" in
    shell_command)
      printf '  -c, --copy     Copy the generated command to the clipboard\n'
      printf '  -x, --execute  Run the generated command after confirmation\n'
      ;;
    text|structured_text)
      printf '  -c, --copy     Copy the response to the clipboard\n'
      ;;
  esac

  while IFS="$TAB" read -r arg_name arg_type arg_long arg_short arg_description arg_default arg_choices; do
    [ "$arg_name" = "name" ] && continue
    [ -n "$arg_name" ] || continue

    line='  '
    if [ -n "$arg_short" ]; then
      line="$line-$arg_short, "
    else
      line="$line    "
    fi
    line="$line--$arg_long"

    case "$arg_type" in
      string)
        line="$line VALUE"
        ;;
      integer)
        line="$line INTEGER"
        ;;
      enum)
        line="$line VALUE"
        ;;
    esac

    while [ "${#line}" -lt 18 ]; do
      line="$line "
    done

    line="$line$arg_description"

    case "$arg_type" in
      enum)
        if [ -n "$arg_choices" ]; then
          line="$line (choices: $arg_choices)"
        fi
        ;;
    esac

    if [ -n "$arg_default" ] && [ "$arg_type" != "flag" ]; then
      line="$line (default: $arg_default)"
    fi

    printf '%s\n' "$line"
  done <"$APP_ARGS_PATH"

  printf '\nExamples:\n'
  while IFS= read -r example || [ -n "$example" ]; do
    [ -n "$example" ] || continue
    printf '  %s\n' "$example"
  done <"$APP_EXAMPLES_PATH"
}

runtime_export_hook_env() {
  app_dir=$1

  export APFELLER_APP_DIR="$app_dir"
  export APFELLER_INPUT="${APPRUN_INPUT:-}"

  while IFS="$TAB" read -r arg_name arg_type arg_long arg_short arg_description arg_default arg_choices; do
    [ "$arg_name" = "name" ] && continue
    [ -n "$arg_name" ] || continue
    env_name=APFELLER_ARG_$(sanitize_name "$arg_name")
    arg_value=$(runtime_get_arg_value "$arg_name")
    export "$env_name=$arg_value"
  done <"$APP_ARGS_PATH"
}

runtime_call_hook() {
  app_dir=$1
  hook_path=$2
  [ -n "$hook_path" ] || return 0
  "$app_dir/$hook_path"
}

runtime_render_prompt() {
  prompt=$APFELLER_PROMPT_TEMPLATE
  prompt=$(template_replace_literal "$prompt" "{{input}}" "${APPRUN_INPUT:-}")

  while IFS="$TAB" read -r arg_name arg_type arg_long arg_short arg_description arg_default arg_choices; do
    [ "$arg_name" = "name" ] && continue
    [ -n "$arg_name" ] || continue
    arg_value=$(runtime_get_arg_value "$arg_name")
    prompt=$(template_replace_literal "$prompt" "{{arg.$arg_name}}" "$arg_value")
  done <"$APP_ARGS_PATH"

  printf '%s\n' "$prompt"
}

runtime_format_structured_text() {
  response=$1
  fields_csv=$2
  response_single_line=$(printf '%s' "$response" | tr '\n' ' ')

  old_ifs=$IFS
  IFS=,
  # shellcheck disable=SC2086
  set -- $fields_csv
  IFS=$old_ifs

  while [ $# -gt 0 ]; do
    field_name=$1
    shift
    next_field=${1-}

    label="$field_name:"
      case "$response_single_line" in
        *"$label"*)
          after_label=${response_single_line#*"$label"}
          ;;
        *)
          fail "$APFELLER_APP_COMMAND returned a response apfeller could not understand. Please try again."
          ;;
      esac

      if [ -n "$next_field" ]; then
        next_label="$next_field:"
        case "$after_label" in
          *"$next_label"*)
            field_value=${after_label%%"$next_label"*}
            ;;
          *)
            fail "$APFELLER_APP_COMMAND returned a response apfeller could not understand. Please try again."
          ;;
        esac
      else
        field_value=$after_label
      fi

      field_value=$(trim "$field_value")
      [ -n "$field_value" ] || fail "$APFELLER_APP_COMMAND returned a response apfeller could not understand. Please try again."
    printf '%s: %s\n' "$field_name" "$field_value"
  done
}

runtime_emit_shell_command() {
  prompt=$1
  response=$(runtime_query_response "$prompt") || return $?
  command_output=$(apfeller_clean_command "$response") || {
    printf '%s\n' "apfeller could not generate a usable command this time. Please try again." >&2
    return 1
  }

  printf '$ %s\n' "$command_output"

  if [ "$RUN_SHOULD_COPY" = "1" ]; then
    apfeller_copy "$command_output" || return $?
    printf '%s\n' "(copied)"
  fi

  if [ "$RUN_SHOULD_EXECUTE" = "1" ] && apfeller_confirm "Run this? [y/N] "; then
    /bin/sh -c "$command_output"
  fi
}

runtime_emit_text() {
  prompt=$1
  response=$(runtime_query_response "$prompt") || return $?
  printf '%s\n' "$response"

  if [ "$RUN_SHOULD_COPY" = "1" ]; then
    apfeller_copy "$response" || return $?
    printf '%s\n' "(copied)"
  fi
}

runtime_emit_structured_text() {
  prompt=$1
  response=$(runtime_query_response "$prompt") || return $?
  formatted=$(runtime_format_structured_text "$response" "$APFELLER_OUTPUT_FIELDS")
  printf '%s\n' "$formatted"

  if [ "$RUN_SHOULD_COPY" = "1" ]; then
    apfeller_copy "$formatted" || return $?
    printf '%s\n' "(copied)"
  fi
}

cmd_run_app() {
  [ $# -ge 1 ] || fail "Usage: apfeller __run-app <app_dir> [args...]"

  app_dir=$1
  shift

  load_runtime_manifest "$app_dir"
  runtime_parse_args "$@"

  if [ "$RUN_SHOW_HELP" = "1" ]; then
    runtime_print_help
    return 0
  fi

  runtime_export_hook_env "$app_dir"
  if [ -n "$APFELLER_HOOK_PRE_RUN" ]; then
    runtime_call_hook "$app_dir" "$APFELLER_HOOK_PRE_RUN"
  fi

  if [ -n "$APFELLER_HOOK_BUILD_PROMPT" ]; then
    prompt=$(runtime_call_hook "$app_dir" "$APFELLER_HOOK_BUILD_PROMPT")
  else
    prompt=$(runtime_render_prompt)
  fi

  apfeller_require_context_budget \
    "$APFELLER_APP_COMMAND" \
    "$APFELLER_PROMPT_MAX_CONTEXT_TOKENS" \
    "$APFELLER_PROMPT_MAX_INPUT_BYTES" \
    "$APFELLER_PROMPT_MAX_OUTPUT_TOKENS" \
    "$prompt" || return $?

  case "$APFELLER_OUTPUT_MODE" in
    shell_command)
      runtime_emit_shell_command "$prompt"
      ;;
    text)
      runtime_emit_text "$prompt"
      ;;
    structured_text)
      runtime_emit_structured_text "$prompt"
      ;;
    *)
      fail "Unsupported output mode: $APFELLER_OUTPUT_MODE"
      ;;
  esac
}

cmd_list() {
  if [ $# -eq 1 ] && [ "$1" = "--installed" ]; then
    if ! state_has_apps; then
      printf '%s\n' "No apps installed."
      return 0
    fi

    catalog_file=$(fetch_catalog)

    while IFS="$TAB" read -r app_id installed_revision command_name installed_at; do
      [ "$app_id" = "id" ] && continue
      resolve_app_state "$app_id" "$catalog_file"
      case "$APP_STATE" in
        installed)
          printf '%s\t%s\tinstalled\t%s\n' "$app_id" "$installed_revision" "$APP_CATALOG_REVISION"
          ;;
        update-available)
          printf '%s\t%s\tupdate-available\t%s\n' "$app_id" "$installed_revision" "$APP_CATALOG_REVISION"
          ;;
        local-only)
          printf '%s\t%s\tlocal-only\t\n' "$app_id" "$installed_revision"
          ;;
      esac
    done <"$STATE_PATH"

    return 0
  fi

  [ $# -eq 0 ] || fail "Usage: apfeller list [--installed]"

  catalog_file=$(fetch_catalog)
  awk -F '\t' 'NR > 1 { print $1 "\t" $2 "\t" $3 }' "$catalog_file" |
    while IFS="$TAB" read -r app_id revision summary; do
      installed_revision=$(state_get_field "$app_id" 2)
      if [ -z "$installed_revision" ]; then
        status="available"
      elif [ "$installed_revision" = "$revision" ]; then
        status="installed"
      else
        status="update-available"
      fi
      printf '%s\t%s\t%s\t%s\n' "$app_id" "$revision" "$status" "$summary"
    done
}

cmd_info() {
  [ $# -eq 1 ] || fail "Usage: apfeller info <app>"

  catalog_file=$(fetch_catalog)
  load_catalog_entry "$1" "$catalog_file" || fail "App not found in the current catalog: $1. Run 'apfeller list' to see what's available."

  requires=${CAT_REQUIRES:-"(none)"}
  supported_shells=${CAT_SUPPORTED_SHELLS:-"(none)"}

  printf 'id: %s\n' "$CAT_ID"
  printf 'revision: %s\n' "$CAT_REVISION"
  printf 'summary: %s\n' "$CAT_SUMMARY"
  printf 'description: %s\n' "$CAT_DESCRIPTION"
  printf 'command: %s\n' "$CAT_COMMAND"
  printf 'kind: %s\n' "$CAT_KIND"
  printf 'requires: %s\n' "$requires"
  printf 'supported_shells: %s\n' "$supported_shells"
  printf 'bundle_url: %s\n' "$CAT_BUNDLE_URL"
  printf 'sha256: %s\n' "$CAT_SHA256"
}

cmd_install() {
  [ $# -gt 0 ] || fail "Usage: apfeller install <app>..."

  ensure_manager_current_for_install "$@"
  catalog_file=$(fetch_catalog)
  for app_id in "$@"; do
    resolve_app_state "$app_id" "$catalog_file"
    case "$APP_STATE" in
      available|update-available)
        install_app "$app_id" "$catalog_file"
        ;;
      installed)
        printf 'Already installed %s %s\n' "$app_id" "$APP_INSTALLED_REVISION"
        ;;
      *)
        fail "App not found in the current catalog: $app_id. Run 'apfeller list' to see what's available."
        ;;
    esac
  done
}

cmd_uninstall() {
  [ $# -gt 0 ] || fail "Usage: apfeller uninstall <app>..."

  for app_id in "$@"; do
    uninstall_app "$app_id"
  done
}

cmd_update() {
  [ $# -gt 0 ] || fail "Usage: apfeller update --self | --all | <app>..."

  case "$1" in
    --self)
      [ $# -eq 1 ] || fail "Usage: apfeller update --self"
      install_manager_from_archive "$SELF_UPDATE_URL" || exit 1
      ;;
    --all)
      [ $# -eq 1 ] || fail "Usage: apfeller update --all"
      if ! state_has_apps; then
        printf '%s\n' "No apps installed."
        return 0
      fi
      catalog_file=$(fetch_catalog)
      while IFS="$TAB" read -r app_id revision command_name installed_at; do
        [ "$app_id" = "id" ] && continue
        resolve_app_state "$app_id" "$catalog_file"
        case "$APP_STATE" in
          update-available)
            install_app "$app_id" "$catalog_file"
            ;;
          installed)
            printf 'Already up to date %s %s\n' "$app_id" "$APP_INSTALLED_REVISION"
            ;;
          local-only)
            print_local_only_warning "$app_id"
            ;;
        esac
      done <"$STATE_PATH"
      ;;
    *)
      catalog_file=$(fetch_catalog)
      for app_id in "$@"; do
        resolve_app_state "$app_id" "$catalog_file"
        case "$APP_STATE" in
          update-available)
            install_app "$app_id" "$catalog_file"
            ;;
          installed)
            printf 'Already up to date %s %s\n' "$app_id" "$APP_INSTALLED_REVISION"
            ;;
          available)
            fail "$app_id is not installed. Run 'apfeller install $app_id' first."
            ;;
          local-only)
            print_local_only_warning "$app_id"
            ;;
          *)
            fail "App not found in the current catalog: $app_id. Run 'apfeller list' to see what's available."
            ;;
        esac
      done
      ;;
  esac
}

cmd_doctor() {
  shell_kind=$(detect_shell_kind "$DETECTED_SHELL")
  manager_path=$(command -v apfeller 2>/dev/null || printf '%s\n' "$LOCAL_BIN_DIR/apfeller")

  case ":${PATH:-}:" in
    *":$LOCAL_BIN_DIR:"*)
      local_bin_status="ok"
      ;;
    *)
      local_bin_status="warn"
      ;;
  esac

  printf 'manager_path\t%s\n' "$manager_path"
  printf 'local_bin_on_path\t%s\n' "$local_bin_status"
  printf 'catalog_url\t%s\n' "$CATALOG_URL"
  printf 'detected_shell\t%s\n' "$shell_kind"
  printf 'state_tsv\t%s\n' "$(status_for_path "$STATE_PATH")"
  printf 'fish_conf\t%s\n' "$(status_for_path "$FISH_CONF_PATH")"
  printf 'zsh_init\t%s\n' "$(status_for_path "$ZSH_INIT_PATH")"
  printf 'fish_completion_dir\t%s\n' "$(status_for_path "$FISH_COMPLETION_DIR")"
  printf 'zsh_completion_dir\t%s\n' "$(status_for_path "$ZSH_COMPLETION_DIR")"
  if command_exists apfel; then
    printf 'apfel\tok\n'
  else
    printf 'apfel\twarn\tInstall with: brew install Arthur-Ficial/tap/apfel\n'
  fi
  printf 'curl\t%s\n' "$(command_exists curl && printf present || printf missing)"
  printf 'tar\t%s\n' "$(command_exists tar && printf present || printf missing)"
  printf 'shasum\t%s\n' "$(command_exists shasum && printf present || printf missing)"

  legacy_state_json="$DATA_DIR/state.json"
  if [ -f "$legacy_state_json" ]; then
    printf 'legacy_state_json\twarn\t%s\n' "$legacy_state_json"
  else
    printf 'legacy_state_json\tok\n'
  fi
}

main() {
  if [ $# -eq 0 ]; then
    print_help
    exit 0
  fi

  case "$1" in
    -h|--help)
      print_help
      exit 0
      ;;
    --version)
      printf 'apfeller %s\n' "$APFELLER_MANAGER_VERSION"
      exit 0
      ;;
  esac

  TMP_DIR=$(mktemp -d "${TMPDIR:-/tmp}/apfeller.XXXXXX")
  CATALOG_CACHE_PATH=""
  trap 'progress_abort; rm -rf "$TMP_DIR"' EXIT INT TERM HUP

  command_name=$1
  shift

  case "$command_name" in
    __run-app)
      cmd_run_app "$@"
      ;;
    list)
      cmd_list "$@"
      ;;
    info)
      cmd_info "$@"
      ;;
    install)
      cmd_install "$@"
      ;;
    uninstall)
      cmd_uninstall "$@"
      ;;
    update)
      cmd_update "$@"
      ;;
    doctor)
      [ $# -eq 0 ] || fail "Usage: apfeller doctor"
      cmd_doctor
      ;;
    *)
      fail "Unknown command: $command_name"
      ;;
  esac
}

main "$@"
