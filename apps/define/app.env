APFELLER_ID=define
APFELLER_VERSION=0.1.0
APFELLER_SUMMARY='Define a word or phrase with apfel.'
APFELLER_DESCRIPTION='Tiny multilingual dictionary lookup with fixed structured output. Supports input and output language selection plus clipboard copy.'
APFELLER_ENTRYPOINT='bin/define'
APFELLER_REQUIRES='apfel,pbcopy,perl'
APFELLER_SUPPORTED_SHELLS='fish,zsh'
APFELLER_BUNDLE_FILES='app.env,bin/define,lib/apfel.sh,completions/fish/define.fish,completions/zsh/_define'
APFELLER_ARCHIVE='define-0.1.0.tar.gz'
