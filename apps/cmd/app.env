APFELLER_ID=cmd
APFELLER_VERSION=0.1.0
APFELLER_SUMMARY='Turn natural language into a shell command with apfel.'
APFELLER_DESCRIPTION='Generate a single macOS shell command from a natural language request. Supports copy-to-clipboard and optional execution after confirmation.'
APFELLER_ENTRYPOINT='bin/cmd'
APFELLER_REQUIRES='apfel,pbcopy'
APFELLER_SUPPORTED_SHELLS='fish,zsh'
APFELLER_BUNDLE_FILES='app.env,bin/cmd,lib/apfel.sh,completions/fish/cmd.fish,completions/zsh/_cmd'
APFELLER_ARCHIVE='cmd-0.1.0.tar.gz'
