APFELLER_ID=port
APFELLER_VERSION=0.1.0
APFELLER_SUMMARY='Show what is using a local port.'
APFELLER_DESCRIPTION='Inspect a local TCP port with lsof and show listeners by default, or all sockets with --all.'
APFELLER_ENTRYPOINT='bin/port'
APFELLER_REQUIRES='lsof'
APFELLER_SUPPORTED_SHELLS='fish,zsh'
APFELLER_BUNDLE_FILES='app.env,bin/port,completions/fish/port.fish,completions/zsh/_port'
APFELLER_ARCHIVE='port-0.1.0.tar.gz'
