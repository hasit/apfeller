APFELLER_ID=oneliner
APFELLER_VERSION=0.1.0
APFELLER_SUMMARY='Turn plain English into a shell one-liner with apfel.'
APFELLER_DESCRIPTION='Generate compact UNIX one-liners and pipe chains from a natural language request using apfel.'
APFELLER_ENTRYPOINT='bin/oneliner'
APFELLER_REQUIRES='apfel,pbcopy'
APFELLER_SUPPORTED_SHELLS='fish,zsh'
APFELLER_BUNDLE_FILES='app.env,bin/oneliner,lib/apfel.sh,completions/fish/oneliner.fish,completions/zsh/_oneliner'
APFELLER_ARCHIVE='oneliner-0.1.0.tar.gz'
